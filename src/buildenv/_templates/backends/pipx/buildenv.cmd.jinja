{% include "headers/warning.jinja" %}

{% include "backends/fragments/check.cmd.jinja" %}

:: Check for requirements
if exist requirements.txt (
    :: Base input requirements
    set _reqs=-r %CD%\requirements.txt
)
if exist buildenv.lock (
    if exist requirements.lock (
        :: Locked requirements
        set _reqs=-r %CD%\requirements.lock
    )
)

:: Delegate execution to buildenv command (through pipx)
call :run_cmd pipx run --pip-args "%_reqs%" %BUILDENV_PIPX_ARGS% buildenv %*
set _BUILDENV_RC=%ERRORLEVEL%
goto end

:end
exit /b %_BUILDENV_RC%

